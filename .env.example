MONGODB_URI=mongodb+srv://...
JWT_SECRET=your_jwt_secret_here
PORT=3000

# Gmail SMTP for sending emails
# Use a Gmail App Password (not your regular password)
# Enable at: Google Account > Security > 2-Step Verification > App Passwords
MAIL_USER=yourname@gmail.com
MAIL_PASS=xxxx xxxx xxxx xxxx
ADMIN_URL=https://your-admin-panel.vercel.app

# Superadmin credentials (used by: node setup.js)
SUPERADMIN_NAME=Super Admin
SUPERADMIN_EMAIL=admin@smartcare.com
SUPERADMIN_PASSWORD=your_password_here
